# Copier ce fichier en .env.local et remplir les valeurs
# Récupérables dans Supabase Dashboard > Settings > API

# URL de ton projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://XXXXX.supabase.co

# Clé publique (anon key) — côté client, sans risque
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service role — JAMAIS exposée côté client, uniquement dans API routes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
